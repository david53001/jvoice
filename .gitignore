# Swift Package Manager
.build/
.swiftpm/
# Package.resolved is deliberately TRACKED (app product, not a library):
# it pins WhisperKit/KeyboardShortcuts revisions so CI and fresh clones
# build exactly what was tested instead of re-resolving `from:` ranges.

# Xcode
DerivedData/
xcuserdata/
*.xcuserstate
*.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# macOS
.DS_Store

# Local logs and temp files
*.log
*.swp
*.swo
docs/assets/demo-src/frames/
.vscode/

# .NET / Windows app (windows/)
windows/**/bin/
windows/**/obj/
windows/**/*.user
windows/.vs/
windows/**/publish/
windows/tools/**/bin/
windows/tools/**/obj/
# Whisper GGML models are downloaded at runtime, never committed
*.bin
