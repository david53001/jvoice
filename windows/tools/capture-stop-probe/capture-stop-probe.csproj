<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>JVoice.Tools.CaptureStopProbe</RootNamespace>
    <AssemblyName>capture-stop-probe</AssemblyName>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
  </PropertyGroup>

  <!-- Compile the REAL capture sources (not copies) so the probe exercises the actual
       production recorder + teardown paths (hotkey-probe precedent). -->
  <ItemGroup>
    <Compile Include="..\..\JVoice.App\Platform\Capture\NAudioRecorder.cs" />
    <Compile Include="..\..\JVoice.App\Platform\Capture\IAudioRecorder.cs" />
    <Compile Include="..\..\JVoice.App\Platform\Capture\AudioInputRouter.cs" />
    <Compile Include="..\..\JVoice.App\Platform\Persistence\PlatformPaths.cs" />
    <Compile Include="..\..\JVoice.App\Platform\System\SystemActions.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="NAudio" Version="2.3.0" />
    <ProjectReference Include="..\..\JVoice.Core\JVoice.Core.csproj" />
  </ItemGroup>

</Project>
