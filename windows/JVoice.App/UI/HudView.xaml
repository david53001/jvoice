<UserControl x:Class="JVoice.App.UI.HudView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             UseLayoutRounding="True" SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             RenderOptions.BitmapScalingMode="HighQuality"
             RenderOptions.ClearTypeHint="Enabled">
    <!-- ===== Voice-bars HUD (black & white) =====
         A deliberately minimal, text-free pill: a black rounded rectangle holding a row
         of slim white rounded lines that form a continuous, mic-independent wave while recording
         (David preferred a constant up/down flow over mic-reactive bars, which stuttered on his
         words — the live-level wiring is kept but UNUSED; see HudView.xaml.cs InputLevelProvider)
         (an indeterminate shimmer while transcribing/preparing/downloading). There is no
         "Recording"/"Listening…" copy and no paste confirmation — only the error state
         carries text. Solid bars also sidestep the layered-window blur that softened the
         old glowy text: WPF renders ClearType-less grayscale AA inside an AllowsTransparency
         window, so small text read as low-resolution; flat rectangles don't.

         HudRootScale (LayoutTransform) enlarges the whole pill so it stays crisp: 1.0 at
         native resolution, more when the desktop runs below native (the monitor's scaler
         interpolates the framebuffer — see DisplayMetrics.HudScale, applied in the
         constructor). LayoutTransform re-runs layout at the larger size, so shapes/text
         stay vector-crisp rather than bitmap-blurred. -->
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="HudRootScale" ScaleX="1.0" ScaleY="1.0" />
        </Grid.LayoutTransform>
        <!-- 16px margin all around = breathing room for the pill's drop shadow. -->
        <Grid Margin="16">
            <!-- ===== the pill body: pure black, squeezed (shorter & a touch longer) ===== -->
            <Border x:Name="PillBody" CornerRadius="19" Background="#FF000000"
                    MinWidth="152" MinHeight="38" BorderThickness="1">
                <Border.BorderBrush>
                    <!-- a hairline so the black pill's edge reads against a dark desktop -->
                    <SolidColorBrush Color="#FFFFFFFF" Opacity="0.10" />
                </Border.BorderBrush>
                <Border.Effect>
                    <!-- a real (black) drop shadow to float the pill — not a colored glow -->
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Direction="270"
                                      Color="#000000" Opacity="0.55" />
                </Border.Effect>

                <!-- tall lines: only a hair of vertical padding so the round-capped lines run
                     from near the top to near the bottom of the pill -->
                <Grid Margin="13,3">
                    <!-- ===== voice-activity bars (recording / transcribing / preparing) =====
                         Rectangles are added in code so the count/size is tunable in one
                         place; each bar's Height is driven per frame from the render loop.
                         Fixed Height + vertically-centered bars makes them grow symmetrically
                         about the mid-line (a mirrored visualizer). -->
                    <StackPanel x:Name="Bars" Orientation="Horizontal"
                                Height="32" HorizontalAlignment="Center" VerticalAlignment="Center" />

                    <!-- ===== error layout (the only state with text) =====
                         Font sizes are deliberately large. Two things soften this text and only
                         a bigger glyph fixes both (you can't get ClearType here — WPF renders
                         grayscale AA inside the AllowsTransparency window, and no app can exempt
                         its window from a below-native monitor's hardware stretch):
                           • grayscale AA blurs small glyphs even at native resolution — the pill
                             historically carried a 1.1× enlargement JUST for text legibility,
                             which the bars-only redesign dropped (HudBaseScale → 1.0) because
                             solid bars don't need it. The error text still does, so it's restored
                             here at the font level (15px vs the old, too-small 11.5px).
                           • below native (e.g. 1600×1080 on a 1920×1080 panel) the monitor
                             interpolates the framebuffer; bigger glyphs get proportionally more
                             device pixels and survive the smear far more legibly.
                         The per-resolution part is automatic: the whole pill is multiplied by
                         DisplayMetrics.HudScale (the stretch ratio) via HudRootScale, so these
                         base sizes scale up further the more the desktop runs below native — the
                         text stays crisp at EVERY resolution without a fixed per-res table.
                         MaxWidth scaled up in step so a typical one-line error doesn't wrap. -->
                    <StackPanel x:Name="ErrorPanel" Orientation="Horizontal" Visibility="Collapsed"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="ErrorGlyph" FontFamily="Segoe MDL2 Assets" FontSize="15"
                                   Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="&#xE7BA;" />
                        <TextBlock x:Name="ErrorText" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FFFFFFFF" VerticalAlignment="Center"
                                   Margin="9,0,0,0" MaxWidth="300" TextWrapping="Wrap"
                                   Text="Something went wrong" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
