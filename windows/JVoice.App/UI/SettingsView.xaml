<UserControl x:Class="JVoice.App.UI.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="clr-namespace:JVoice.App.UI"
             Width="960" Background="{StaticResource Settings.PanelBg}">
    <!-- ===== Three-column (masonry) Settings layout =====
         A full-width header (row 0), a three-column body of cards (row 1), and a full-width
         footer (row 2). The three body columns are independent vertical StackPanels so cards of
         very different heights pack tip-to-tail with no cross-column height coupling. Three
         columns (was two) keep the whole panel SHORT — everything is visible at once without the
         window growing taller than the screen's work area, so the title-bar close (X) is always
         reachable (David runs a non-native 1600x1080 desktop; a ~1080-tall window pushed the X
         off the top). Each column is still ~300px wide — identical to the old two-column card
         width — so no card gets more cramped than before; the panel just got wider, not the cards
         narrower.

         The four list cards (Recent Transcripts, Custom Words, Corrections, App Modes rules) are
         spread so no single column balloons when populated; each list is also internally height-
         capped (MaxHeight + inner scroll).

         The view has NO fixed Height: it sizes to its content and the hosting SettingsWindow uses
         SizeToContent, so the window is exactly as tall as the cards need. SettingsWindow also
         clamps MaxHeight to the screen work area as a guard, and the outer ScrollViewer scrolls if
         a future card ever overflows — the X can never be pushed off-screen again.

         HorizontalScrollBarVisibility="Disabled" is REQUIRED: it gives the body a finite width so
         the star columns resolve — without it the layout collapses at an infinite measure width. -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 1. Header (full width) -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="JVoice" FontSize="17" FontWeight="Bold" Foreground="White" />
                <TextBlock Text="Voice dictation controls" FontSize="11" Foreground="{StaticResource Text.W45}" Margin="0,3,0,0" />
            </StackPanel>

            <!-- ===== Three-column body ===== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ===================== COLUMN 1 ===================== -->
                <StackPanel Grid.Column="0">

                    <!-- STATS (green) — three-up: total words | avg WPM | time saved -->
                    <ui:DarkSection HeaderText="Stats" AccentBrush="{StaticResource Settings.Green}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalWordsSpoken}" FontSize="22" FontWeight="Bold" Foreground="White"
                                           FontFamily="Consolas" HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#FFFFFF" Opacity="0.28" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="total words" FontSize="10" Foreground="{StaticResource Text.W38}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Grid.Column="1" Width="0.5" Height="44" Fill="{StaticResource Settings.Border}" />
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AverageWpmDisplay}" FontSize="22" FontWeight="Bold" Foreground="White"
                                           FontFamily="Consolas" HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#FFFFFF" Opacity="0.28" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="avg WPM" FontSize="10" Foreground="{StaticResource Text.W38}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <Rectangle Grid.Column="3" Width="0.5" Height="44" Fill="{StaticResource Settings.Border}" />
                            <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TimeSavedDisplay}" FontSize="22" FontWeight="Bold" Foreground="White"
                                           FontFamily="Consolas" HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#FFFFFF" Opacity="0.28" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="time saved" FontSize="10" Foreground="{StaticResource Text.W38}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </ui:DarkSection>

                    <!-- RECENT TRANSCRIPTS (blue) — read-only history of the last 30 dictations -->
                    <ui:DarkSection HeaderText="Recent Transcripts" AccentBrush="{StaticResource Settings.Blue}">
                        <StackPanel>
                            <TextBlock Text="No transcripts yet." FontSize="11"
                                       Foreground="{StaticResource Text.W40}"
                                       Visibility="{Binding HasRecentTranscripts, Converter={StaticResource InverseBoolToVis}}" />
                            <ScrollViewer MaxHeight="150" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasRecentTranscripts, Converter={StaticResource BoolToVis}}">
                                <ItemsControl ItemsSource="{Binding RecentTranscripts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Single-line, read-only row. Hover highlights it and reveals Copy + Delete. -->
                                            <Border CornerRadius="6" Padding="6,3" Margin="0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <!-- Transparent (not null) so the whole row is hit-testable for hover. -->
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#1AFFFFFF" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Text}" FontSize="11"
                                                               Foreground="{StaticResource Text.W75}"
                                                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                               VerticalAlignment="Center" />
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"
                                                                Visibility="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}, Converter={StaticResource BoolToVis}}">
                                                        <!-- Copy — flips to a checkmark for ~1.2s after a click -->
                                                        <Button Style="{StaticResource PressableButton}" Click="OnCopyTranscript"
                                                                Margin="6,0,0,0" ToolTip="Copy" Foreground="#B3FFFFFF">
                                                            <Grid>
                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="13"
                                                                           Visibility="{Binding JustCopied, Converter={StaticResource InverseBoolToVis}}" />
                                                                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" FontSize="13"
                                                                           Visibility="{Binding JustCopied, Converter={StaticResource BoolToVis}}" />
                                                            </Grid>
                                                        </Button>
                                                        <!-- Delete just this row -->
                                                        <Button Style="{StaticResource PressableButton}" Click="OnDeleteTranscript"
                                                                Margin="10,0,0,0" ToolTip="Delete"
                                                                FontFamily="Segoe MDL2 Assets" Content="&#xECC9;" FontSize="13"
                                                                Foreground="#B3FFFFFF" />
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <Button Content="Clear all" Style="{StaticResource DarkPrimaryButton}"
                                    HorizontalAlignment="Left" Margin="0,8,0,0"
                                    Foreground="{StaticResource Settings.Gray}" Tag="{StaticResource Settings.Gray}"
                                    Click="OnClearTranscripts"
                                    Visibility="{Binding HasRecentTranscripts, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- WHISPER MODEL (cyan) -->
                    <ui:DarkSection HeaderText="Whisper Model" AccentBrush="{StaticResource Settings.Cyan}">
                        <StackPanel>
                            <UniformGrid Rows="1">
                                <RadioButton Content="Tiny"  GroupName="Model" Style="{StaticResource SegmentLeft}"  IsChecked="{Binding IsTiny, Mode=TwoWay}" />
                                <RadioButton Content="Base"  GroupName="Model" Style="{StaticResource SegmentMid}"   IsChecked="{Binding IsBase, Mode=TwoWay}" />
                                <RadioButton Content="Small" GroupName="Model" Style="{StaticResource SegmentMid}"   IsChecked="{Binding IsSmall, Mode=TwoWay}" />
                                <RadioButton Content="Large" GroupName="Model" Style="{StaticResource SegmentRight}" IsChecked="{Binding IsLarge, Mode=TwoWay}" />
                            </UniformGrid>
                            <TextBlock Text="{Binding ModelGuidance}" FontSize="10" Foreground="{StaticResource Text.W38}"
                                       TextWrapping="Wrap" Margin="0,7,0,0" />

                            <!-- Recommendation / warning callout (monochrome). Large is the default and the
                                 recommended choice; this always advises keeping it, and an extra caution line
                                 (bound to IsLarge via InverseBoolToVis) appears only when a smaller model is
                                 picked. Segoe MDL2 Assets glyph E7BA is the standard Warning triangle, matching
                                 the icon font used elsewhere in Settings. -->
                            <Border CornerRadius="6" Background="#14FFFFFF" BorderBrush="{StaticResource Settings.Border}"
                                    BorderThickness="1" Padding="9,8" Margin="0,10,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="13"
                                               Foreground="White" VerticalAlignment="Top" Margin="0,1,8,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource Text.W75}">
                                            <Run FontWeight="SemiBold" Foreground="White">Keep this on Large.</Run>
                                            <Run Text=" It's the most accurate model, and with GPU acceleration it's just as fast as the smaller ones. Only switch to a smaller model if you really know why you need to &#8212; for example an older, CPU-only PC where Large runs slowly." />
                                        </TextBlock>
                                        <TextBlock FontSize="10" Foreground="White" TextWrapping="Wrap" Margin="0,6,0,0"
                                                   Text="You've picked a smaller model &#8212; accuracy may drop. Switch back to Large unless you have a specific reason."
                                                   Visibility="{Binding IsLarge, Converter={StaticResource InverseBoolToVis}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- VOICE STYLE (purple) -->
                    <ui:DarkSection HeaderText="Voice Style" AccentBrush="{StaticResource Settings.Purple}">
                        <UniformGrid Rows="1">
                            <RadioButton Content="Casual"      GroupName="Tone" Style="{StaticResource SegmentLeft}"
                                         IsChecked="{Binding IsCasual, Mode=TwoWay}" />
                            <RadioButton Content="Formal"      GroupName="Tone" Style="{StaticResource SegmentMid}"
                                         IsChecked="{Binding IsFormal, Mode=TwoWay}" />
                            <RadioButton Content="Very Casual" GroupName="Tone" Style="{StaticResource SegmentRight}"
                                         IsChecked="{Binding IsVeryCasual, Mode=TwoWay}" />
                        </UniformGrid>
                    </ui:DarkSection>

                </StackPanel>

                <!-- ===================== COLUMN 2 ===================== -->
                <StackPanel Grid.Column="2">

                    <!-- LANGUAGE (indigo) -->
                    <ui:DarkSection HeaderText="Language" AccentBrush="{StaticResource Settings.Indigo}">
                        <StackPanel>
                            <UniformGrid Rows="1">
                                <RadioButton Content="English"  GroupName="Lang" Style="{StaticResource SegmentLeft}"
                                             IsChecked="{Binding IsEnglish, Mode=TwoWay}" />
                                <RadioButton Content="Romanian" GroupName="Lang" Style="{StaticResource SegmentRight}"
                                             IsChecked="{Binding IsRomanian, Mode=TwoWay}" />
                            </UniformGrid>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Translate to English" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text.W85}" />
                                    <TextBlock Text="Speak the language above, paste English" FontSize="10" Foreground="{StaticResource Text.W38}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                          Style="{StaticResource MonoSwitch}"
                                          IsChecked="{Binding TranslateToEnglish, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- PROCESSING (teal) -->
                    <ui:DarkSection HeaderText="Processing" AccentBrush="{StaticResource Settings.Teal}">
                        <StackPanel>
                            <!-- Each row is a 2-column grid: a star text column (with a right
                                 margin + wrapping subtitle) and an Auto switch column, so the
                                 subtitle can never slide under the toggle. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Remove Filler Words" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text.W85}" />
                                    <TextBlock Text="Strip um, uh, er, ah, hmm from output" FontSize="10" Foreground="{StaticResource Text.W38}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                          Style="{StaticResource MonoSwitch}"
                                          IsChecked="{Binding RemoveFillerWords, Mode=TwoWay}" />
                            </Grid>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Developer Terms" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text.W85}" />
                                    <TextBlock Text="Fix coding terms: Node.js, GitHub, TypeScript, JSON, C#&#8230;" FontSize="10" Foreground="{StaticResource Text.W38}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                          Style="{StaticResource MonoSwitch}"
                                          IsChecked="{Binding DeveloperTermsEnabled, Mode=TwoWay}" />
                            </Grid>
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Copy to Clipboard" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text.W85}" />
                                    <TextBlock Text="Copy the text instead of auto-pasting it" FontSize="10" Foreground="{StaticResource Text.W38}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                          Style="{StaticResource MonoSwitch}"
                                          IsChecked="{Binding CopyToClipboardOnly, Mode=TwoWay}" />
                            </Grid>
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- CUSTOM WORDS (orange) -->
                    <ui:DarkSection HeaderText="Custom Words" AccentBrush="{StaticResource Settings.Orange}">
                        <StackPanel>
                            <TextBlock Text="No custom words added." FontSize="11" Foreground="{StaticResource Text.W40}"
                                       Visibility="{Binding HasCustomWords, Converter={StaticResource InverseBoolToVis}}" />
                            <ScrollViewer MaxHeight="88" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasCustomWords, Converter={StaticResource BoolToVis}}">
                                <ItemsControl ItemsSource="{Binding CustomWords}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource Text.W75}" HorizontalAlignment="Left" />
                                                <Button HorizontalAlignment="Right" Style="{StaticResource PressableButton}"
                                                        Click="OnRemoveWord" Tag="{Binding}"
                                                        FontFamily="Segoe MDL2 Assets" Content="&#xECC9;"
                                                        Foreground="#B3FFFFFF" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <!-- Flexible add row: star input column + Auto button, so "Add" is never clipped. -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="6" Background="{StaticResource Settings.InputBg}"
                                        BorderBrush="{StaticResource Settings.Border}" BorderThickness="1">
                                    <TextBox x:Name="NewWordBox" Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource Text.W75}" FontSize="11" Padding="8,5"
                                             KeyDown="OnNewWordKeyDown" />
                                </Border>
                                <Button Grid.Column="1" Content="Add" Style="{StaticResource DarkPrimaryButton}" Margin="6,0,0,0"
                                        Foreground="{StaticResource Settings.Orange}" Tag="{StaticResource Settings.Orange}"
                                        Click="OnAddWord" />
                            </Grid>
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- GAMING (gray) -->
                    <ui:DarkSection HeaderText="Gaming" AccentBrush="{StaticResource Settings.Gray}">
                        <StackPanel>
                            <UniformGrid Rows="1">
                                <RadioButton Content="Off"        GroupName="GameMode" Style="{StaticResource SegmentLeft}"
                                             IsChecked="{Binding IsGameOff, Mode=TwoWay}" />
                                <RadioButton Content="Balanced"   GroupName="GameMode" Style="{StaticResource SegmentMid}"
                                             IsChecked="{Binding IsGameBalanced, Mode=TwoWay}" />
                                <RadioButton Content="Aggressive" GroupName="GameMode" Style="{StaticResource SegmentRight}"
                                             IsChecked="{Binding IsGameAggressive, Mode=TwoWay}" />
                            </UniformGrid>
                            <TextBlock Text="Pause the hotkey while a game is in focus. Balanced = detected games only; Aggressive = also any fullscreen app."
                                       FontSize="10" Foreground="{StaticResource Text.W38}" TextWrapping="Wrap" Margin="0,7,0,0" />
                        </StackPanel>
                    </ui:DarkSection>

                </StackPanel>

                <!-- ===================== COLUMN 3 ===================== -->
                <StackPanel Grid.Column="4">

                    <!-- APP MODES (teal) — auto-switch the tone by foreground app -->
                    <ui:DarkSection HeaderText="App Modes" AccentBrush="{StaticResource Settings.Teal}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Auto-switch by App" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text.W85}" />
                                    <TextBlock Text="Terminals, VS Code &amp; IDEs use Code mode automatically" FontSize="10" Foreground="{StaticResource Text.W38}"
                                               TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                          Style="{StaticResource MonoSwitch}"
                                          IsChecked="{Binding AppAwareModes, Mode=TwoWay}" />
                            </Grid>

                            <!-- Custom per-app rules -->
                            <TextBlock Text="Custom rules — pick one of your open apps (or type a name), choose a mode, then Add."
                                       FontSize="10" Foreground="{StaticResource Text.W38}" TextWrapping="Wrap" Margin="0,12,0,6" />
                            <TextBlock Text="No custom rules added." FontSize="11" Foreground="{StaticResource Text.W40}"
                                       Visibility="{Binding HasAppModeRules, Converter={StaticResource InverseBoolToVis}}" />
                            <ScrollViewer MaxHeight="88" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasAppModeRules, Converter={StaticResource BoolToVis}}">
                                <ItemsControl ItemsSource="{Binding AppModeRules}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding AppMatch}" FontSize="11" Foreground="{StaticResource Text.W75}" />
                                                    <TextBlock Text="&#x2192;" FontSize="11" Foreground="{StaticResource Text.W40}" Margin="6,0,6,0" />
                                                    <TextBlock Text="{Binding Mode}" FontSize="11" Foreground="{StaticResource Settings.Teal}" />
                                                </StackPanel>
                                                <Button HorizontalAlignment="Right" Style="{StaticResource PressableButton}"
                                                        Click="OnRemoveAppRule" Tag="{Binding}"
                                                        FontFamily="Segoe MDL2 Assets" Content="&#xECC9;"
                                                        Foreground="#B3FFFFFF" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <!-- Add row: searchable open-app picker + click-to-cycle mode chip + Add. -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="6" Background="{StaticResource Settings.InputBg}"
                                        BorderBrush="{StaticResource Settings.Border}" BorderThickness="1">
                                    <Grid>
                                        <TextBox x:Name="AppRuleBox" Background="Transparent" BorderThickness="0"
                                                 Foreground="{StaticResource Text.W75}" FontSize="11" Padding="8,5"
                                                 GotKeyboardFocus="OnAppRuleFocus" TextChanged="OnAppRuleTextChanged"
                                                 KeyDown="OnAppRuleKeyDown" />
                                        <!-- Watermark (toggled in code-behind when the box is empty). -->
                                        <TextBlock x:Name="AppRuleWatermark" Text="Search your open apps&#8230;" FontSize="11"
                                                   Foreground="{StaticResource Text.W35}" Margin="9,0,0,0"
                                                   IsHitTestVisible="False" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <!-- Filtered dropdown of currently-open apps (styled dark to match). -->
                                <Popup x:Name="AppPickerPopup" PlacementTarget="{Binding ElementName=AppRuleBox}"
                                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                                       Width="{Binding ActualWidth, ElementName=AppRuleBox}">
                                    <Border Background="{StaticResource Settings.PanelBg}" BorderBrush="{StaticResource Settings.Border}"
                                            BorderThickness="1" CornerRadius="6" Margin="0,2,0,0">
                                        <ListBox x:Name="AppPickerList" Background="Transparent" BorderThickness="0" MaxHeight="176"
                                                 SelectionChanged="OnAppPicked" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="8,4" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="row" Background="{TemplateBinding Background}" CornerRadius="4"
                                                                        Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="row" Property="Background" Value="#1AFFFFFF" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="row" Property="Background" Value="#26FFFFFF" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Display}" FontSize="11" Foreground="{StaticResource Text.W85}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Exe}" FontSize="9" Foreground="{StaticResource Text.W38}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </Popup>
                                <Button x:Name="AppRuleModeButton" Grid.Column="1" Style="{StaticResource DarkPrimaryButton}" Margin="6,0,0,0"
                                        MinWidth="80" Content="Code" Foreground="{StaticResource Settings.Teal}" Tag="{StaticResource Settings.Teal}"
                                        Click="OnCycleAppRuleMode" ToolTip="Click to change the mode this rule applies" />
                                <Button Grid.Column="2" Content="Add" Style="{StaticResource DarkPrimaryButton}" Margin="6,0,0,0"
                                        Foreground="{StaticResource Settings.Teal}" Tag="{StaticResource Settings.Teal}"
                                        Click="OnAddAppRule" />
                            </Grid>
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- CORRECTIONS (pink) — Windows-only; kept adjacent to Custom Words -->
                    <ui:DarkSection HeaderText="Corrections" AccentBrush="{StaticResource Settings.Pink}">
                        <StackPanel>
                            <TextBlock FontSize="10" Foreground="{StaticResource Text.W38}" TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Text="Replace a misheard word or phrase in the final text. Tip: use the whole phrase (e.g. &quot;web api&quot; &#x2192; &quot;web app&quot;) so other uses of the word (like &quot;REST API&quot;) stay untouched." />
                            <TextBlock Text="No corrections added." FontSize="11" Foreground="{StaticResource Text.W40}"
                                       Visibility="{Binding HasCorrections, Converter={StaticResource InverseBoolToVis}}" />
                            <ScrollViewer MaxHeight="88" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding HasCorrections, Converter={StaticResource BoolToVis}}">
                                <ItemsControl ItemsSource="{Binding Corrections}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding From}" FontSize="11" Foreground="{StaticResource Text.W75}" />
                                                    <TextBlock Text="&#x2192;" FontSize="11" Foreground="{StaticResource Text.W40}" Margin="6,0,6,0" />
                                                    <TextBlock Text="{Binding To}" FontSize="11" Foreground="{StaticResource Settings.Pink}" />
                                                </StackPanel>
                                                <Button HorizontalAlignment="Right" Style="{StaticResource PressableButton}"
                                                        Click="OnRemoveCorrection" Tag="{Binding}"
                                                        FontFamily="Segoe MDL2 Assets" Content="&#xECC9;"
                                                        Foreground="#B3FFFFFF" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <!-- Flexible add row: two star input columns split the space, Auto arrow + Auto button. -->
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="6" Background="{StaticResource Settings.InputBg}"
                                        BorderBrush="{StaticResource Settings.Border}" BorderThickness="1">
                                    <TextBox x:Name="CorrectionFromBox" Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource Text.W75}" FontSize="11" Padding="8,5"
                                             KeyDown="OnCorrectionKeyDown" />
                                </Border>
                                <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="12" Foreground="{StaticResource Text.W40}"
                                           VerticalAlignment="Center" Margin="6,0,6,0" />
                                <Border Grid.Column="2" CornerRadius="6" Background="{StaticResource Settings.InputBg}"
                                        BorderBrush="{StaticResource Settings.Border}" BorderThickness="1">
                                    <TextBox x:Name="CorrectionToBox" Background="Transparent" BorderThickness="0"
                                             Foreground="{StaticResource Text.W75}" FontSize="11" Padding="8,5"
                                             KeyDown="OnCorrectionKeyDown" />
                                </Border>
                                <Button Grid.Column="3" Content="Add" Style="{StaticResource DarkPrimaryButton}" Margin="6,0,0,0"
                                        Foreground="{StaticResource Settings.Pink}" Tag="{StaticResource Settings.Pink}"
                                        Click="OnAddCorrection" />
                            </Grid>
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- KEYBOARD SHORTCUT (gray) -->
                    <ui:DarkSection HeaderText="Keyboard Shortcut" AccentBrush="{StaticResource Settings.Gray}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Toggle Recording:" FontSize="11" Foreground="{StaticResource Text.W75}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ui:HotkeyRecorder x:Name="Recorder" MinWidth="120" Padding="8,4"
                                                   Background="{StaticResource Settings.InputBg}"
                                                   Foreground="{StaticResource Text.W75}" />
                            </StackPanel>
                            <TextBlock Text="Default: Ctrl + Shift + Space" FontSize="10"
                                       Foreground="{StaticResource Text.W35}" Margin="0,8,0,0" />

                            <!-- Optional undo-last-paste chord (off by default; a global chord is swallowed
                                 system-wide, so it's opt-in — pick a rare combo). -->
                            <Rectangle Height="0.5" Fill="{StaticResource Settings.Border}" Margin="0,12,0,12" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Undo Last Paste:" FontSize="11" Foreground="{StaticResource Text.W75}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                <ui:HotkeyRecorder x:Name="UndoRecorder" MinWidth="120" Padding="8,4" Content="None"
                                                   Background="{StaticResource Settings.InputBg}"
                                                   Foreground="{StaticResource Text.W75}" />
                                <Button Content="Clear" Style="{StaticResource DarkPrimaryButton}" Margin="8,0,0,0"
                                        Foreground="{StaticResource Settings.Gray}" Tag="{StaticResource Settings.Gray}"
                                        Click="OnClearUndoHotkey"
                                        Visibility="{Binding HasUndoHotkey, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>
                            <TextBlock Text="Optional — sends the app's Undo (Ctrl+Z) to reverse the last paste." FontSize="10"
                                       Foreground="{StaticResource Text.W35}" TextWrapping="Wrap" Margin="0,8,0,0" />
                        </StackPanel>
                    </ui:DarkSection>

                    <!-- UPDATES (green) — in-app version check + one-click update (root CLAUDE.md §7 #34) -->
                    <ui:DarkSection HeaderText="Updates" AccentBrush="{StaticResource Settings.Green}">
                        <StackPanel>
                            <!-- Auto-check toggle -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                    <TextBlock Text="Automatic Updates" FontSize="12" FontWeight="Medium" Foreground="{StaticResource Text.W85}" />
                                    <TextBlock Text="Check GitHub for a new version. No data is sent." FontSize="10"
                                               Foreground="{StaticResource Text.W38}" TextWrapping="Wrap" Margin="0,2,0,0" />
                                </StackPanel>
                                <CheckBox Grid.Column="1" VerticalAlignment="Center"
                                          Style="{StaticResource MonoSwitch}"
                                          IsChecked="{Binding CheckForUpdatesAutomatically, Mode=TwoWay}" />
                            </Grid>

                            <!-- Current version + manual check -->
                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource Text.W75}">
                                    <Run Text="Version " /><Run Text="{Binding Updates.CurrentVersionDisplay, Mode=OneWay}" />
                                </TextBlock>
                                <Button Grid.Column="1" Content="Check Now" Style="{StaticResource DarkPrimaryButton}"
                                        Foreground="{StaticResource Settings.Green}" Tag="{StaticResource Settings.Green}"
                                        Click="OnCheckForUpdates"
                                        Visibility="{Binding Updates.CanCheck, Converter={StaticResource BoolToVis}}" />
                            </Grid>

                            <!-- Status line (checking / up to date / available / errors) -->
                            <TextBlock Text="{Binding Updates.StatusText}" FontSize="10" Foreground="{StaticResource Text.W45}"
                                       TextWrapping="Wrap" Margin="0,8,0,0"
                                       Visibility="{Binding Updates.HasStatus, Converter={StaticResource BoolToVis}}" />

                            <!-- Update button (only when a newer version is available) -->
                            <Button Content="Update Now" Style="{StaticResource DarkPrimaryButton}" HorizontalAlignment="Left"
                                    Margin="0,8,0,0" Foreground="{StaticResource Settings.Green}" Tag="{StaticResource Settings.Green}"
                                    Click="OnUpdateNow"
                                    Visibility="{Binding Updates.ShowUpdateButton, Converter={StaticResource BoolToVis}}" />

                            <!-- Eased download bar: a plain fill Border (no % text) whose width is the
                                 eased progress × the track width. The fill glides via UpdateCoordinator's
                                 smoothing timer; full only when the download actually completes. -->
                            <Border x:Name="UpdateProgressTrack" Height="6" CornerRadius="3" Margin="0,10,0,2"
                                    Background="#22FFFFFF" ClipToBounds="True"
                                    Visibility="{Binding Updates.ShowProgress, Converter={StaticResource BoolToVis}}">
                                <Border HorizontalAlignment="Left" CornerRadius="3" Background="White">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource FractionToWidth}">
                                            <Binding Path="Updates.Progress" />
                                            <Binding Path="ActualWidth" ElementName="UpdateProgressTrack" />
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                            </Border>
                        </StackPanel>
                    </ui:DarkSection>

                </StackPanel>
            </Grid>

            <!-- Footer: Restore Defaults / Quit (full width) -->
            <Grid Grid.Row="2">
                <Button Content="Restore Default Settings" Style="{StaticResource DarkDestructiveButton}"
                        HorizontalAlignment="Left" Click="OnRestoreDefaults" />
                <Button Content="Quit JVoice" Style="{StaticResource DarkDestructiveButton}"
                        HorizontalAlignment="Right" Click="OnQuit" />
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
